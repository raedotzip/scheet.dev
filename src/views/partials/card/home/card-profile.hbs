<div class="card card--profile">
  <div class="profile-text">
    <h2>{{name}}</h2>
    <div class="profile-bio">
      {{#each bio}}
        <p>{{this}}</p>
      {{/each}}
    </div>
  </div>
  <img src="{{image}}" alt="{{name}}" id="rae-card-profile-img"/>
  <div class="social-grid">
    {{#each socials}}
      <a class="social" href="{{href}}">
        <img src="{{image}}" alt="{{type}}"/>
      </a>
    {{/each}}
  </div>
</div>